### Inscribir alumno en materia (necesitarás esta ruta también)
POST http://localhost:3000/api/enrollments
Content-Type: application/json

{
    "student_id": 2,
    "subject_id": 1
}

export const getStudentsBySubjectService = async (subject_id) => {
  // Verificar que la materia existe
  const subjectResult = await query(
    `SELECT id FROM subjects WHERE id = $1 AND deleted_at IS NULL`,
    [subject_id]
  );

  if (subjectResult.rows.length === 0) {
    return [];
  }

  const result = await query(
    `SELECT e.id as enrollment_id, e.grade, e.created_at as enrolled_at,
            u.id, u.name, u.email, u.role
     FROM enrollments e
     INNER JOIN users u ON e.student_id = u.id AND u.deleted_at IS NULL
     WHERE e.subject_id = $1 AND e.deleted_at IS NULL`,
    [subject_id]
  );

  return result.rows;
};

